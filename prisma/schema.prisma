// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Klant {
  id         String     @id @default(cuid())
  naam       String
  email      String?
  telefoon   String?
  adres      String?
  postcode   String?
  plaats     String?
  kvkNummer  String?
  notities   String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  offertes   Offerte[]
  facturen   Factuur[]
  expenses   Expense[]
  projecten  Project[]
}

model Project {
  id              String    @id @default(cuid())
  projectNummer   String    @unique
  naam            String
  locatie         String?
  klantId         String
  klant           Klant     @relation(fields: [klantId], references: [id], onDelete: Cascade)
  status          String    @default("Actief") // Actief, Afgerond, Geannuleerd
  notities        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  offertes        Offerte[]
  facturen        Factuur[]
  expenses        Expense[]
  planningItems   PlanningItem[]

  @@index([klantId])
  @@index([status])
}

model Prijslijst {
  id              String   @id @default(cuid())
  categorie       String
  omschrijving    String
  prijsPerEenheid Int
  eenheid         String
  materiaalKosten Int      @default(0)
  actief          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Offerte {
  id                      String         @id @default(cuid())
  offerteNummer           String         @unique
  datum                   DateTime       @default(now())
  geldigTot               DateTime
  klantId                 String
  klant                   Klant          @relation(fields: [klantId], references: [id], onDelete: Cascade)
  projectId               String?
  project                 Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectNaam             String
  projectLocatie          String?
  items                   OfferteItem[]
  subtotaal               Int
  btwPercentage           Float
  btwBedrag               Int
  totaal                  Int
  status                  String         @default("Concept")
  emailVerzonden          Boolean        @default(false)
  vooruitbetaald          Boolean        @default(false) // 30% prepayment received
  molliePaymentId         String?        // Last processed Mollie payment ID for idempotency
  notities                String?
  bekeken                 Boolean        @default(false)
  bekekenOp               DateTime?      // When client first viewed signing page
  // Signature fields
  klantHandtekening       String?        // Base64 signature image
  klantNaam               String?        // Name of person who signed
  klantGetekendOp         DateTime?      // When client signed
  klantIpAdres            String?        // IP address of client
  bedrijfHandtekening     String?        // Company signature
  bedrijfNaam             String?        // Company representative name
  bedrijfGetekendOp       DateTime?      // When company signed
  algemeneVoorwaardenUrl  String?        // URL to AV PDF
  algemeneVoorwaardenHash String?        // Hash of AV for verification
  expenses                Expense[]
  facturen                Factuur[]     // Invoices generated from this quote
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([datum])
  @@index([status])
  @@index([klantId])
}

model OfferteItem {
  id              String   @id @default(cuid())
  offerteId       String
  offerte         Offerte  @relation(fields: [offerteId], references: [id], onDelete: Cascade)
  omschrijving    String
  aantal          Float
  eenheid         String
  prijsPerEenheid Int
  totaal          Int
  btwTarief       String   @default("HOOG_21")
  btwBedrag       Int      @default(0)
  volgorde        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Factuur {
  id                      String        @id @default(cuid())
  factuurNummer           String        @unique
  datum                   DateTime      @default(now())
  vervaldatum             DateTime
  klantId                 String
  klant                   Klant         @relation(fields: [klantId], references: [id], onDelete: Cascade)
  projectId               String?
  project                 Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectNaam             String
  projectLocatie          String?
  items                   FactuurItem[]
  subtotaal               Int
  btwPercentage           Float
  btwBedrag               Int
  totaal                  Int
  status                  String        @default("Concept")
  herinneringen           FactuurHerinnering[]
  betaaldBedrag           Int           @default(0)
  offerteId               String?       // Source offerte if generated from quote
  offerte                 Offerte?      @relation(fields: [offerteId], references: [id], onDelete: SetNull)
  molliePaymentId         String?       // Last processed Mollie payment ID for idempotency
  emailVerzonden          Boolean       @default(false)
  notities                String?
  // Signature fields
  klantHandtekening       String?       // Base64 signature image
  klantNaam               String?       // Name of person who signed
  klantGetekendOp         DateTime?     // When client signed
  klantIpAdres            String?       // IP address of client
  algemeneVoorwaardenUrl  String?       // URL to AV PDF
  algemeneVoorwaardenHash String?       // Hash of AV for verification
  expenses                Expense[]
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  
  @@index([datum])
  @@index([status])
  @@index([klantId])
  @@index([vervaldatum])
  @@index([offerteId])
}

model FactuurItem {
  id              String   @id @default(cuid())
  factuurId       String
  factuur         Factuur  @relation(fields: [factuurId], references: [id], onDelete: Cascade)
  omschrijving    String
  aantal          Float
  eenheid         String
  prijsPerEenheid Int
  totaal          Int
  btwTarief       String   @default("HOOG_21")
  btwBedrag       Int      @default(0)
  volgorde        Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Email {
  id              String   @id @default(cuid())
  type            String   // "offerte" or "factuur"
  documentId      String   // ID of offerte or factuur
  documentNummer  String   // OFF-YYYY-XXX or FACT-YYYY-XXX
  recipient       String   // Email address
  recipientName   String   // Client name
  subject         String
  body            String
  status          String   @default("verzonden") // "verzonden", "mislukt", "gepland"
  errorMessage    String?
  sentAt          DateTime @default(now())
  openedAt        DateTime? // When email was opened (future feature)
  clickedAt       DateTime? // When link was clicked (future feature)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([type])
  @@index([documentId])
  @@index([sentAt])
}

model Expense {
  id                String    @id @default(cuid())
  klantId           String?
  klant             Klant?    @relation(fields: [klantId], references: [id], onDelete: SetNull)
  offerteId         String?
  offerte           Offerte?  @relation(fields: [offerteId], references: [id], onDelete: SetNull)
  factuurId         String?
  factuur           Factuur?  @relation(fields: [factuurId], references: [id], onDelete: SetNull)
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Receipt/Expense details
  datum             DateTime  @default(now())
  categorie         String    // "Materialen", "Transport", "Gereedschap", "Voertuig", "Abonnementen", "Onderaanneming", "Overig"
  omschrijving      String
  bedrag            Int
  btw               Int       @default(0)
  totaalBedrag      Int
  
  // Receipt image
  imageUrl          String?   // Path to uploaded image
  imageName         String?   // Original filename
  imageSize         Int?      // File size in bytes
  
  // OCR extracted data
  ocrText           String?   // Full extracted text
  ocrBedrag         Int?      // Auto-detected amount (cents)
  ocrDatum          DateTime? // Auto-detected date
  ocrWinkel         String?   // Auto-detected store name
  ocrVerified       Boolean   @default(false) // Manual verification
  
  // Metadata
  uploadedVia       String    @default("web") // "web", "mobile"
  notities          String?
  status            String    @default("pending") // "pending", "approved", "rejected"
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  @@index([klantId])
  @@index([projectId])
  @@index([datum])
  @@index([categorie])
  @@index([status])
}

model PlanningItem {
  id          String    @id @default(cuid())
  titel       String
  startDatum  DateTime
  eindDatum   DateTime
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  notities    String?
  kleurCode   String    @default("#3b82f6") // blue-500
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startDatum])
  @@index([eindDatum])
  @@index([projectId])
}

model FactuurHerinnering {
  id          String   @id @default(cuid())
  factuurId   String
  factuur     Factuur  @relation(fields: [factuurId], references: [id], onDelete: Cascade)
  type        String   // VRIENDELIJK, ZAKELIJK, LAATSTE
  verzondOp   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([factuurId])
}

